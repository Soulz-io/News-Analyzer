# OpenClaw News Analyzer — Environment Variables
# Copy this file to .env and fill in your API keys.
# The engine loads .env automatically at startup.

# --- LLM Providers ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Data Providers ---
FRED_API_KEY=

# --- Telegram Push Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Twitter / X OSINT ---
X_BEARER_TOKEN=

# --- Engine Settings (optional) ---
# ENGINE_PORT=9120
# ENGINE_HOST=0.0.0.0
# LOG_LEVEL=INFO
# FETCH_INTERVAL_MINUTES=15
# ML_ENABLED=false
